            <stringProp name="script">
vars.put(&quot;Var_FirstName&quot;, &quot;PerfApril&quot; + new Date().getTime().toString().substring(0,10))
vars.put(&quot;Var_LastName&quot;, &quot;Ln&quot; + new Date().getTime().toString().substring(0,10))
def chars = &quot;abcdefghijklmnopqrstuvwxyz&quot;
def rand = new Random()
def randomStr = (1..5).collect { chars[rand.nextInt(chars.length())] }.join()
vars.put(&quot;Var_Email&quot;, &quot;Perf&quot; + randomStr)
vars.put(&quot;Var_Phone&quot;, &quot;41567567&quot; + (11 + rand.nextInt(88)).toString())
              </stringProp>
