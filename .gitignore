# JMeter Test Files (stored in S3, not GitHub)
# Ignore entire tests directory - test files should be uploaded to S3, not committed to GitHub
tests/
data/*.csv
data/*.txt

# Generated API tests (auto-generated from browser tests)
generated-api-tests/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# AWS CDK
iac/cdk.out/
iac/node_modules/
iac/.cdk.staging/

# TypeScript build artifacts (auto-generated, should not be committed)
iac/**/*.js
iac/**/*.d.ts
# Keep Lambda function files (these are source, not build artifacts)
!iac/lambda/**/*.js

# Temporary files
*.log
*.tmp
*.bak

# AWS credentials (never commit)
.aws/
credentials
*.pem
*.key

# Build artifacts
dist/
build/
*.pyc
__pycache__/

# Local test results
results/
*.jtl
# Ignore JMeter result XML files, but keep configuration files
*.jmx.xml
results*.xml
summary*.xml
# Allow Log4j2 config
!docker/log4j2.xml

# IAM Policy Files (NEVER commit - security sensitive)
# These contain AWS IAM permissions and should only exist locally
github-actions-trust-policy.json
github-actions-permissions.json
github-actions-cdk-permissions.json
docs/iam/*.json
*-trust-policy.json
*-permissions.json
*-policy.json

# Prevent markdown documentation files
*.md
*.MD
README*
CHANGELOG*

# Personal/temporary folders
k6-framework-personal/

# Temporary log and debug files (TR deployment cleanup)
*-logs.txt
*-logs.json
cloudwatch-logs.json
execution-*.json
temp-*.jmx
temp-*.txt
temp-*.py
function.zip
response.json
sfn-definition.json
after-screenshots.json
complete-logs.json
full-upload-sequence.json
latest-upload-logs.json

# Temporary scripts (local debugging)
analyze-*.py
check-*.py
fetch-*.py
verify-*.js

# Node modules (will be installed via npm)
node_modules/

# CDK build outputs
cdk.out/
